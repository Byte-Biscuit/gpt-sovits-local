# --- Runtime Mode Settings (Local or Colab) ---
# Environment configuration choice, options: local, colab
# ENV_MODE=local

# --- Local Configuration ---
LOCAL_ASSETS_DIR=/opt/local/gpt-sovits/assets
LOCAL_MODELS_DIR=/opt/local/gpt-sovits/models

# --- Colab Configuration (Google Drive) ---
COLAB_ASSETS_DIR=/content/drive/MyDrive/gpt-sovits/assets
